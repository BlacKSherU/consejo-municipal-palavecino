---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Quiénes somos — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Quiénes somos</h1>
    <div id="about-root" class="prose prose-slate mt-8 max-w-none dark:prose-invert">
      <p class="text-slate-500">Cargando…</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";
  import { apiUrl } from "../lib/api";

  async function load() {
    const root = document.getElementById("about-root");
    if (!root) return;
    try {
      const res = await fetch(apiUrl("/api/site/about"));
      const data = await res.json();
      root.innerHTML = marked.parse(data.body || "");
    } catch {
      root.innerHTML = "<p>No se pudo cargar el contenido.</p>";
    }
  }
  load();
</script>
