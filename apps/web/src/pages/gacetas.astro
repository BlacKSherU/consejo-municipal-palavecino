---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gacetas oficiales — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    <header class="text-center">
      <p
        class="text-xs font-semibold uppercase tracking-[0.25em] text-brand dark:text-brand-muted"
      >
        Documentación oficial
      </p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
        Gacetas oficiales
      </h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Ordenanzas municipales y documentos oficiales en PDF.
      </p>
      <div class="mx-auto mt-8 max-w-md space-y-1">
        <div class="mx-auto h-0.5 w-full rounded-full bg-brand opacity-90 dark:bg-brand-muted"></div>
        <div class="mx-auto h-0.5 w-4/5 rounded-full bg-brand-teal opacity-70"></div>
        <div class="mx-auto h-0.5 w-3/5 rounded-full bg-brand-sky opacity-50"></div>
      </div>
    </header>

    <div
      class="mt-12 overflow-hidden rounded-2xl border border-slate-200/90 bg-white/95 shadow-lg shadow-brand/5 backdrop-blur-sm dark:border-slate-700/80 dark:bg-slate-900/90 dark:shadow-brand/10"
    >
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr
              class="border-b border-slate-200 bg-gradient-to-r from-slate-50 to-white dark:border-slate-700 dark:from-slate-800 dark:to-slate-900"
            >
              <th scope="col" class="px-4 py-3.5 font-semibold text-slate-800 dark:text-slate-100">Título</th>
              <th scope="col" class="px-4 py-3.5 font-semibold text-slate-800 dark:text-slate-100">Número</th>
              <th scope="col" class="px-4 py-3.5 font-semibold text-slate-800 dark:text-slate-100">Fecha</th>
              <th scope="col" class="px-4 py-3.5 font-semibold text-slate-800 dark:text-slate-100">Descarga</th>
            </tr>
          </thead>
          <tbody id="gazette-rows">
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td colspan="4" class="px-4 py-10 text-center text-slate-500 dark:text-slate-400" aria-live="polite">
                Cargando…
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    <p id="gazette-err" class="mt-4 text-center text-sm text-red-600 dark:text-red-400"></p>
  </div>
</BaseLayout>

<script>
  import { initGacetasPage } from "../scripts/load-gacetas-page";
  void initGacetasPage();
</script>
