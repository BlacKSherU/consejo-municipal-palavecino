---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gacetas oficiales — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Gacetas oficiales</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-400">
      Órdenanzas municipales y documentos oficiales en PDF.
    </p>
    <div class="mt-10 overflow-x-auto rounded-2xl border border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
      <table class="min-w-full text-left text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800">
          <tr>
            <th class="px-4 py-3 font-semibold">Título</th>
            <th class="px-4 py-3 font-semibold">Número</th>
            <th class="px-4 py-3 font-semibold">Fecha</th>
            <th class="px-4 py-3 font-semibold">Descarga</th>
          </tr>
        </thead>
        <tbody id="gazette-rows"></tbody>
      </table>
    </div>
    <p id="gazette-err" class="mt-4 text-sm text-red-600"></p>
  </div>
</BaseLayout>

<script>
  import { apiUrl } from "../lib/api";

  async function load() {
    const tbody = document.getElementById("gazette-rows");
    const err = document.getElementById("gazette-err");
    if (!tbody) return;
    try {
      const res = await fetch(apiUrl("/api/gazettes"));
      const data = await res.json();
      const items = data.items || [];
      tbody.innerHTML = "";
      for (const g of items) {
        const tr = document.createElement("tr");
        tr.className = "border-b border-slate-100 dark:border-slate-800";
        tr.innerHTML = `
          <td class="px-4 py-3 font-medium text-slate-900 dark:text-slate-100">${escapeHtml(g.title)}</td>
          <td class="px-4 py-3 text-slate-600">${escapeHtml(g.issue_number || "")}</td>
          <td class="px-4 py-3 text-slate-600">${escapeHtml(g.published_at || "")}</td>
          <td class="px-4 py-3">
            <a class="font-semibold text-brand hover:underline" href="${apiUrl("/api/gazettes/" + g.id + "/download")}" download>PDF</a>
          </td>
        `;
        tbody.appendChild(tr);
      }
      if (items.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="px-4 py-6 text-slate-500">No hay gacetas publicadas.</td></tr>`;
      }
    } catch {
      if (err) err.textContent = "Error al cargar gacetas.";
    }
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/"/g, "&quot;");
  }

  load();
</script>
