---
import BaseLayout from "../layouts/BaseLayout.astro";
import GacetasHomeIsland from "../components/GacetasHomeIsland";
---

<BaseLayout title="Gacetas oficiales — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    <header class="text-center">
      <p
        class="text-xs font-semibold uppercase tracking-[0.25em] text-brand dark:text-brand-muted"
      >
        Documentación oficial
      </p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
        Gacetas oficiales
      </h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Ordenanzas municipales y documentos oficiales en PDF.
      </p>
      <div class="mx-auto mt-8 max-w-md space-y-1">
        <div class="mx-auto h-0.5 w-full rounded-full bg-brand opacity-90 dark:bg-brand-muted"></div>
        <div class="mx-auto h-0.5 w-4/5 rounded-full bg-brand-teal opacity-70"></div>
        <div class="mx-auto h-0.5 w-3/5 rounded-full bg-brand-sky opacity-50"></div>
      </div>
    </header>

    <p class="mt-4 text-center text-sm text-slate-600 dark:text-slate-400">
      <a href="/gacetas/buscar" class="font-semibold text-brand hover:underline dark:text-brand-muted">Buscar todas las gacetas</a>
      (por título, número, archivo o fecha).
    </p>

    <div
      class="mt-8 rounded-2xl border border-slate-200/90 bg-white/95 shadow-lg shadow-brand/5 backdrop-blur-sm dark:border-slate-700/80 dark:bg-slate-900/90 dark:shadow-brand/10"
    >
      <GacetasHomeIsland client:load />
    </div>
  </div>
</BaseLayout>
