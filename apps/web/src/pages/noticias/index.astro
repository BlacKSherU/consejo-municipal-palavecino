---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Noticias — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Noticias</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-400">Comunicados y actualizaciones institucionales.</p>
    <ul id="news-list" class="mt-10 space-y-6"></ul>
    <p id="news-err" class="mt-4 text-sm text-red-600"></p>
  </div>
</BaseLayout>

<script>
  import { apiUrl } from "../../lib/api";

  async function load() {
    const list = document.getElementById("news-list");
    const err = document.getElementById("news-err");
    if (!list) return;
    try {
      const res = await fetch(apiUrl("/api/news"));
      const data = await res.json();
      const items = data.items || [];
      list.innerHTML = "";
      for (const n of items) {
        const li = document.createElement("li");
        li.className =
          "rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900";
        li.innerHTML = `
          <a href="/noticias/detalle?slug=${encodeURIComponent(n.slug)}" class="text-xl font-semibold text-brand hover:underline">${n.title}</a>
          <p class="mt-2 text-sm text-slate-500">${n.published_at || ""}</p>
          <p class="mt-3 text-slate-600 dark:text-slate-300">${n.excerpt || ""}</p>
        `;
        list.appendChild(li);
      }
      if (items.length === 0) list.innerHTML = "<li>No hay noticias publicadas.</li>";
    } catch (e) {
      if (err) err.textContent = "Error al cargar noticias.";
    }
  }
  load();
</script>
