---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Noticia — Consejo Municipal de Palavecino">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
    <a
      href="/noticias"
      class="group mb-8 inline-flex items-center gap-2 text-sm font-semibold text-brand transition hover:text-brand-dark dark:text-brand-muted dark:hover:text-brand-sky"
    >
      <span aria-hidden="true" class="transition-transform group-hover:-translate-x-0.5">←</span>
      Volver a noticias
    </a>

    <div id="article-root" class="min-h-[12rem]">
      <div
        class="flex animate-pulse flex-col gap-4 rounded-2xl border border-slate-200/80 bg-slate-50/80 p-8 dark:border-slate-800 dark:bg-slate-900/50"
        aria-hidden="true"
      >
        <div class="h-40 rounded-xl bg-slate-200/80 dark:bg-slate-800"></div>
        <div class="h-6 w-2/3 rounded bg-slate-200 dark:bg-slate-800"></div>
        <div class="h-4 w-1/3 rounded bg-slate-200 dark:bg-slate-800"></div>
        <div class="mt-4 space-y-2">
          <div class="h-3 w-full rounded bg-slate-200 dark:bg-slate-800"></div>
          <div class="h-3 w-full rounded bg-slate-200 dark:bg-slate-800"></div>
          <div class="h-3 w-4/5 rounded bg-slate-200 dark:bg-slate-800"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { initNewsDetail } from "../../scripts/load-news-detail";
  void initNewsDetail();
</script>
