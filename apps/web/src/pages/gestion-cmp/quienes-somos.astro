---
import AdminShellLayout from "../../layouts/AdminShellLayout.astro";
---

<AdminShellLayout title="Quiénes somos">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Quiénes somos</h1>
  <p class="mt-2 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
    Misión, visión, galería (URLs <code class="text-xs">https://</code>) y cuerpo en Markdown. Visible en la página pública
    <a href="/quienes-somos" class="text-brand hover:underline" target="_blank" rel="noopener noreferrer">/quienes-somos</a>.
  </p>

  <form id="about-form" class="mt-8 max-w-3xl space-y-8">
    <section class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100">Misión</h2>
      <textarea
        name="mission"
        id="about-mission"
        rows="5"
        class="mt-2 w-full rounded-lg border border-slate-300 p-3 text-sm dark:border-slate-600 dark:bg-slate-950"
        placeholder="Propósito y razón de ser del consejo…"
      ></textarea>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100">Visión</h2>
      <textarea
        name="vision"
        id="about-vision"
        rows="5"
        class="mt-2 w-full rounded-lg border border-slate-300 p-3 text-sm dark:border-slate-600 dark:bg-slate-950"
        placeholder="Horizonte deseado a mediano plazo…"
      ></textarea>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <div class="flex flex-wrap items-end justify-between gap-2">
        <div>
          <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100">Imágenes (galería)</h2>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Solo URLs HTTPS. Máximo 12. Texto alternativo recomendado.</p>
        </div>
        <button
          type="button"
          id="img-add"
          class="rounded-lg border border-slate-300 bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-800 hover:bg-white dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700"
        >
          + Añadir imagen
        </button>
      </div>
      <div id="img-rows" class="mt-4 space-y-3"></div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100">Cuerpo (Markdown)</h2>
      <textarea
        name="body"
        id="about-body"
        rows="16"
        class="mt-2 w-full rounded-lg border border-slate-300 p-4 font-mono text-sm dark:border-slate-600 dark:bg-slate-950"
      ></textarea>
    </section>

    <p id="about-msg" class="text-sm text-green-700 dark:text-green-400"></p>
    <button type="submit" class="rounded-xl bg-brand px-6 py-2 text-sm font-semibold text-white">Guardar todo</button>
  </form>
</AdminShellLayout>

<script>
  import { initAdminAboutForm } from "../../scripts/admin-about-form";
  initAdminAboutForm();
</script>
