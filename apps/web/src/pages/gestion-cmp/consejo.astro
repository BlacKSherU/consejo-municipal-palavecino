---
import AdminShellLayout from "../../layouts/AdminShellLayout.astro";
---

<AdminShellLayout title="Consejo">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Puestos y consejales</h1>

  <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900">
    <h2 class="text-lg font-semibold">Nuevo puesto</h2>
    <form id="pos-form" class="mt-4 flex flex-wrap gap-3">
      <input name="name" required placeholder="Nombre del puesto" class="flex-1 rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      <input name="sort_order" type="number" placeholder="Orden" class="w-24 rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      <button type="submit" class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white">Añadir</button>
    </form>
    <ul id="pos-list" class="mt-6 space-y-2"></ul>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900">
    <h2 class="text-lg font-semibold">Nuevo consejal</h2>
    <form id="mem-form" class="mt-4 grid gap-3 sm:grid-cols-2">
      <label class="sm:col-span-2">
        <span class="text-sm font-medium">Puesto</span>
        <select name="position_id" id="mem-pos" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950"></select>
      </label>
      <label class="sm:col-span-2">
        <span class="text-sm font-medium">Nombre completo</span>
        <input name="full_name" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label class="sm:col-span-2">
        <span class="text-sm font-medium">Biografía</span>
        <textarea name="bio" rows="4" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950"></textarea>
      </label>
      <label>
        <span class="text-sm font-medium">Email</span>
        <input name="email" type="email" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label>
        <span class="text-sm font-medium">Teléfono</span>
        <input name="phone" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label>
        <span class="text-sm font-medium">Orden</span>
        <input name="sort_order" type="number" value="0" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <div class="flex items-end">
        <button type="submit" class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white">Añadir consejal</button>
      </div>
    </form>
  </section>

  <section class="mt-10">
    <h2 class="text-lg font-semibold">Consejales</h2>
    <div id="mem-list" class="mt-4 space-y-6"></div>
  </section>
</AdminShellLayout>

<script>
  import { apiFetch } from "../../lib/api";

  let positionsCache: { id: number; name: string }[] = [];

  async function loadPositions() {
    const res = await apiFetch("/api/admin/council/positions");
    const data = await res.json();
    positionsCache = data.items || [];
    const sel = document.getElementById("mem-pos") as HTMLSelectElement;
    if (sel) {
      sel.innerHTML = positionsCache.map((p) => `<option value="${p.id}">${escapeHtml(p.name)}</option>`).join("");
    }
    const ul = document.getElementById("pos-list");
    if (ul) {
      ul.innerHTML = "";
      for (const p of positionsCache) {
        const li = document.createElement("li");
        li.className = "flex items-center justify-between gap-2 rounded border border-slate-200 px-3 py-2 dark:border-slate-700";
        li.innerHTML = `<span>${escapeHtml(p.name)}</span>
          <button type="button" class="text-sm text-red-600" data-del-pos="${p.id}">Eliminar</button>`;
        ul.appendChild(li);
        li.querySelector(`[data-del-pos="${p.id}"]`)?.addEventListener("click", async () => {
          if (!confirm("¿Eliminar puesto y consejales asociados?")) return;
          await apiFetch("/api/admin/council/positions/" + p.id, { method: "DELETE" });
          loadAll();
        });
      }
    }
  }

  async function loadMembers() {
    const res = await apiFetch("/api/council");
    const data = await res.json();
    const root = document.getElementById("mem-list");
    if (!root) return;
    root.innerHTML = "";
    const positions = data.positions || [];
    for (const p of positions) {
      const members = p.members || [];
      for (const m of members) {
        const card = document.createElement("div");
        card.className = "rounded-xl border border-slate-200 p-4 dark:border-slate-700";
        card.innerHTML = `
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="font-semibold">${escapeHtml(m.full_name)}</p>
              <p class="text-xs text-slate-500">${escapeHtml(p.name)}</p>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300 whitespace-pre-wrap">${escapeHtml(m.bio || "")}</p>
            </div>
            <div class="flex flex-col gap-2">
              <label class="text-xs">Foto<input type="file" accept="image/*" data-photo="${m.id}" class="block w-full text-xs" /></label>
              <button type="button" class="text-sm text-red-600" data-del-m="${m.id}">Eliminar</button>
            </div>
          </div>
        `;
        root.appendChild(card);
        card.querySelector(`[data-del-m="${m.id}"]`)?.addEventListener("click", async () => {
          if (!confirm("¿Eliminar consejal?")) return;
          await apiFetch("/api/admin/council/members/" + m.id, { method: "DELETE" });
          loadAll();
        });
        card.querySelector(`[data-photo="${m.id}"]`)?.addEventListener("change", async (ev) => {
          const input = ev.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const fd = new FormData();
          fd.set("file", file);
          await apiFetch("/api/admin/council/members/" + m.id + "/photo", { method: "POST", body: fd });
          alert("Foto actualizada");
          loadAll();
        });
      }
    }
  }

  function escapeHtml(s: string) {
    return String(s || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/"/g, "&quot;");
  }

  async function loadAll() {
    await loadPositions();
    await loadMembers();
  }

  document.getElementById("pos-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    await apiFetch("/api/admin/council/positions", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        name: fd.get("name"),
        sort_order: Number(fd.get("sort_order") || 0),
      }),
    });
    (e.target as HTMLFormElement).reset();
    loadAll();
  });

  document.getElementById("mem-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    await apiFetch("/api/admin/council/members", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        position_id: Number(fd.get("position_id")),
        full_name: fd.get("full_name"),
        bio: fd.get("bio"),
        email: fd.get("email") || null,
        phone: fd.get("phone") || null,
        sort_order: Number(fd.get("sort_order") || 0),
      }),
    });
    (e.target as HTMLFormElement).reset();
    loadAll();
  });

  loadAll();
</script>
