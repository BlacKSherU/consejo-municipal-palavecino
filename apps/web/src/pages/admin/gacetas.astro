---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Gacetas">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Gacetas oficiales</h1>

  <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-900">
    <h2 class="text-lg font-semibold">Subir PDF</h2>
    <form id="gazette-form" class="mt-4 space-y-3">
      <label class="block text-sm">
        Título
        <input name="title" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label class="block text-sm">
        Número / edición
        <input name="issue_number" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label class="block text-sm">
        Fecha de publicación
        <input name="published_at" type="date" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 dark:border-slate-600 dark:bg-slate-950" />
      </label>
      <label class="block text-sm">
        Archivo PDF
        <input name="file" type="file" accept="application/pdf" required class="mt-1 w-full text-sm" />
      </label>
      <button type="submit" class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white">Subir</button>
    </form>
  </section>

  <section class="mt-10">
    <h2 class="text-lg font-semibold">Publicadas</h2>
    <div id="gazette-list" class="mt-4 space-y-3"></div>
  </section>
</AdminLayout>

<script>
  import { apiFetch, apiUrl } from "../../lib/api";

  async function loadList() {
    const root = document.getElementById("gazette-list");
    if (!root) return;
    const res = await apiFetch("/api/admin/gazettes");
    const data = await res.json();
    const items = data.items || [];
    root.innerHTML = "";
    for (const g of items) {
      const row = document.createElement("div");
      row.className = "flex flex-wrap items-center justify-between gap-2 rounded-lg border border-slate-200 p-3 dark:border-slate-700";
      row.innerHTML = `
        <div>
          <p class="font-medium">${escapeHtml(g.title)}</p>
          <p class="text-xs text-slate-500">${escapeHtml(g.issue_number || "")} · ${escapeHtml(g.published_at || "")}</p>
        </div>
        <div class="flex gap-3">
          <a class="text-sm text-brand hover:underline" href="${apiUrl("/api/gazettes/" + g.id + "/download")}" target="_blank">Ver PDF</a>
          <button type="button" class="text-sm text-red-600 hover:underline" data-del="${g.id}">Eliminar</button>
        </div>
      `;
      root.appendChild(row);
      row.querySelector(`[data-del="${g.id}"]`)?.addEventListener("click", async () => {
        if (!confirm("¿Eliminar esta gaceta?")) return;
        await apiFetch("/api/admin/gazettes/" + g.id, { method: "DELETE" });
        loadList();
      });
    }
  }

  function escapeHtml(s: string) {
    return String(s || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/"/g, "&quot;");
  }

  document.getElementById("gazette-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const res = await apiFetch("/api/admin/gazettes", {
      method: "POST",
      body: fd,
    });
    if (res.ok) {
      form.reset();
      loadList();
    } else {
      alert("Error al subir");
    }
  });

  loadList();
</script>
