# Copia este archivo como .dev.vars (no subir a git) y rellena.
# Wrangler carga .dev.vars en `wrangler dev`.

JWT_SECRET=local-dev-cambiar
# CORS_ORIGIN = origen del sitio Astro/Pages (https://…), NO la URL del Worker.
# Si falta o no coincide EXACTAMENTE con la barra del navegador, verás "NetworkError when attempting to fetch".
# Varios orígenes (coma, sin espacios):
# CORS_ORIGIN=https://tu-proyecto.pages.dev,http://localhost:4321,http://127.0.0.1:4321

# Opcional — Instagram Graph API
# META_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
