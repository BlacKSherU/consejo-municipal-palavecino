# Copy to .env on the server (never commit .env).
# settings.py carga este archivo con python-dotenv (tras: pip install -r requirements.txt).

# Variables que SÍ lee Django (prefijo DJANGO_):
# DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# El puerto NO es un setting de Django: no pongas PORT=8000 esperando que runserver/gunicorn
# lo lean desde aquí. Usa la línea de comando, p. ej.:
#   python manage.py runserver 0.0.0.0:8001
#   gunicorn ... --bind 127.0.0.1:8000
# O define PORT en systemd/supervisor y úsalo en ExecStart (--bind 127.0.0.1:$PORT).
